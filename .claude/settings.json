{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "Edit",
      "Write"
    ],
    "deny": [
      "// === Destructive file operations ===",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(sudo:*)",

      "// === Force WebFetch for web access (prompt-injection containment) ===",
      "Bash(curl:*)",
      "Bash(wget:*)",

      "// === Git destructive operations ===",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin --force:*)",
      "Bash(git push origin -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",

      "// === Infrastructure ===",
      "Bash(docker system prune:*)",
      "Bash(docker rm:*)",
      "Bash(docker rmi:*)",

      "// === Dangerous permission changes ===",
      "Bash(chmod 777:*)"
    ]
  }
}
